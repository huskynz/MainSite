@model IReadOnlyList<_12.Models.TimelineEvent>
@{
    ViewData["Title"] = "Timeline";
}
<section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl font-bold mb-12 text-center text-gray-900 dark:text-white">
            My Journey
        </h2>

        <div class="relative">
            <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-gray-300 dark:bg-gray-600"></div>

            <div class="space-y-12">
                @foreach (var timelineYear in Model)
                {
                    <div class="relative">
                        <div class="absolute left-4 w-4 h-4 rounded-full border-4 border-white dark:border-gray-900 @timelineYear.CategoryColorClass"></div>

                        <div class="ml-16">
                            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md border border-gray-200 dark:border-gray-700 p-6">
                                <h3 class="text-2xl font-bold text-husky-purple dark:text-husky-pink mb-4">
                                    @timelineYear.Year
                                </h3>

                                <ul class="space-y-3">
                                    @foreach (var item in timelineYear.Events)
                                    {
                                        <li class="flex items-start gap-3">
                                            <div class="mt-2 w-2 h-2 rounded-full @timelineYear.CategoryColorClass flex-shrink-0"></div>
                                            <span class="text-gray-700 dark:text-gray-300 leading-relaxed">
                                                @item
                                            </span>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
